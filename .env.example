# MongoDB
MONGODB_URI=mongodb+srv://username:password@cluster.mongodb.net/healthcare

# JWT Secret (generate a random string)
JWT_SECRET=your_super_secret_jwt_key_here

# Email (Gmail) for OTP
EMAIL_USER=your_gmail@gmail.com
EMAIL_PASS=your_gmail_app_password

# Groq API - free at https://console.groq.com
GROQ_API_KEY=your_groq_api_key_here

# Sarvam AI - free at https://dashboard.sarvam.ai
SARVAM_API_KEY=your_sarvam_api_key_here

# Google Maps - https://console.cloud.google.com (enable Places API)
GOOGLE_MAPS_API_KEY=your_google_maps_api_key_here

# MongoDB
MONGODB_URI=mongodb+srv://username:password@cluster.mongodb.net/healthcare

# JWT Secret (generate a random string)
JWT_SECRET=your_super_secret_jwt_key_here

# Brevo (Sendinblue) - free at https://app.brevo.com (300 emails/day, no domain needed)
BREVO_API_KEY=your_brevo_api_key_here
BREVO_SENDER_EMAIL=your_verified_email@gmail.com

# Groq API - free at https://console.groq.com
GROQ_API_KEY=your_groq_api_key_here

# Sarvam AI - free at https://dashboard.sarvam.ai
SARVAM_API_KEY=your_sarvam_api_key_here

# Google Maps - https://console.cloud.google.com (enable Places API)
GOOGLE_MAPS_API_KEY=your_google_maps_api_key_here
